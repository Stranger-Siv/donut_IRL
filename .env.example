# Copy to .env.local for local dev
MONGODB_URI=mongodb://127.0.0.1:27017/donut_irl
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-long-random-string-for-production

# Optional: public trade feed & Discord
DISCORD_WEBHOOK_URL=
# Optional: n8n / automation posting to /api/webhooks/discord
INTERNAL_DISCORD_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Password reset by email: use Resend (recommended) or SMTP
# RESEND_API_KEY=re_...
# Optional override (default works on Resend test domain): EMAIL_FROM=Donut IRL <noreply@yourdomain.com>
# Or Gmail / any SMTP: SMTP_HOST=smtp.gmail.com SMTP_PORT=587 SMTP_SECURE=false SMTP_USER=... SMTP_PASS=app-password
